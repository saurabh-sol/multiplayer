# Database Connection (Neon Serverless)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Server Port
PORT=3001

# CORS - comma-separated list of allowed origins (leave empty to allow all)
# Example: https://playtrezo.com,http://localhost:8080,http://localhost:8081
CORS_ORIGINS=https://playtrezo.com,http://localhost:8080,http://localhost:8081
